{
  "name": "geometry-kernel-workbench",
  "displayName": "Geometry Kernel Workbench",
  "description": "Inspect GKS geometry snapshots with topology trees, properties, compare views, and Three.js rendering.",
  "version": "0.1.4",
  "publisher": "gk-workbench",
  "license": "UNLICENSED",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/plxdhong/gks_view.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/plxdhong/gks_view#readme",
  "bugs": {
    "url": "https://github.com/plxdhong/gks_view/issues"
  },
  "qna": false,
  "preview": true,
  "extensionKind": [
    "workspace"
  ],
  "keywords": [
    "geometry",
    "cad",
    "topology",
    "gks",
    "opencascade",
    "kernel",
    "viewer",
    "gtest",
    "threejs",
    "debug"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://github.com/plxdhong/gks_view/actions/workflows/vscode-extension-ci.yml/badge.svg",
      "href": "https://github.com/plxdhong/gks_view/actions/workflows/vscode-extension-ci.yml",
      "description": "VSCode Extension CI"
    }
  ],
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Visualization",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:gkWorkbench.gkcase",
    "onCustomEditor:gkWorkbench.gkscene",
    "onCustomEditor:gkWorkbench.gkcompare",
    "onCustomEditor:gkWorkbench.gkrun",
    "onCommand:gkWorkbench.openSnapshot",
    "onCommand:gkWorkbench.openLatestRun",
    "onCommand:gkWorkbench.revealEntity"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gkWorkbench.openSnapshot",
        "title": "Geometry: Open Snapshot"
      },
      {
        "command": "gkWorkbench.openLatestRun",
        "title": "Geometry: Open Latest Test Run"
      },
      {
        "command": "gkWorkbench.openCompare",
        "title": "Geometry: Open Compare View"
      },
      {
        "command": "gkWorkbench.attachAdapter",
        "title": "Geometry: Attach Kernel Adapter"
      },
      {
        "command": "gkWorkbench.runAdapterCommand",
        "title": "Geometry: Run Adapter Command"
      },
      {
        "command": "gkWorkbench.revealEntity",
        "title": "Geometry: Reveal Entity"
      }
    ],
    "customEditors": [
      {
        "viewType": "gkWorkbench.gkcase",
        "displayName": "Geometry Workbench Case",
        "selector": [
          {
            "filenamePattern": "*.gkcase.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "gkWorkbench.gkscene",
        "displayName": "Geometry Workbench Scene",
        "selector": [
          {
            "filenamePattern": "*.gkscene.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "gkWorkbench.gkcompare",
        "displayName": "Geometry Workbench Compare",
        "selector": [
          {
            "filenamePattern": "*.gkcompare.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "gkWorkbench.gkrun",
        "displayName": "Geometry Workbench Run",
        "selector": [
          {
            "filenamePattern": "*.gkrun.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "bun run build:extension && bun run build:webview",
    "build:extension": "tsc -p tsconfig.json",
    "build:webview": "vite build --config webview/vite.config.ts",
    "dev": "vite --host 127.0.0.1 --config webview/vite.config.ts",
    "package:vsix": "bun ../../scripts/package-vscode-extension.mjs",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "dependencies": {
    "@gk-workbench/gks-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/three": "^0.165.0",
    "@types/vscode": "^1.88.0",
    "@vscode/vsce": "^3.9.2",
    "three": "^0.165.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.12"
  }
}
