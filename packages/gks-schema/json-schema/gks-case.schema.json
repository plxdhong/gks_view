{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gk-workbench.local/schema/gks-case.schema.json",
  "title": "GKS Case",
  "type": "object",
  "required": ["gksVersion", "caseId", "snapshots"],
  "additionalProperties": true,
  "properties": {
    "gksVersion": {
      "const": "0.1"
    },
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "producer": {
      "type": "object",
      "additionalProperties": true
    },
    "snapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["snapshotId", "file"],
        "additionalProperties": true,
        "properties": {
          "snapshotId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

