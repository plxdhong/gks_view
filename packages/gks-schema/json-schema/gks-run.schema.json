{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gk-workbench.local/schema/gks-run.schema.json",
  "title": "GKS Run",
  "type": "object",
  "required": ["gksVersion", "runId", "cases"],
  "additionalProperties": true,
  "properties": {
    "gksVersion": {
      "const": "0.1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "rootDir": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["caseId", "file"],
        "additionalProperties": true,
        "properties": {
          "caseId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "suite": {
            "type": "string"
          },
          "test": {
            "type": "string"
          },
          "status": {
            "enum": ["running", "passed", "failed", "skipped", "unknown"]
          },
          "startedAt": {
            "type": "string"
          },
          "finishedAt": {
            "type": "string"
          }
        }
      }
    }
  }
}
